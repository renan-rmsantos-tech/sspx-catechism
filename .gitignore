# See https://help.github.com/articles/ignoring-files/

# ─── dependencies ─────────────────────────────────────────────
/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── environment (nunca secrets; .env.example pode ser versionado) ─
.env
.env.*
.envrc
!.env.example
!.env.sample

# ─── Next.js ──────────────────────────────────────────────────
/.next/
/out/
next-env.d.ts

# PWA — gerado em `npm run build` (@ducanh2912/next-pwa → public/)
/public/sw.js
/public/sw.js.map
/public/workbox-*.js
/public/workbox-*.js.map
/public/swe-worker-*.js
/public/fallback-*.js

# ─── build / bundlers ─────────────────────────────────────────
/build
/.turbo
.cache/
.parcel-cache/
.eslintcache

# ─── testing & coverage ───────────────────────────────────────
/coverage
*.lcov

# ─── Supabase (CLI local) ─────────────────────────────────────
.branches/
supabase/.branches/
supabase/.temp/

# ─── Vercel ───────────────────────────────────────────────────
.vercel

# ─── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo

# ─── logs & debug ─────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── IDE / editor ─────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ─── certs & keys ─────────────────────────────────────────────
*.pem
*.p12

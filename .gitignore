# See https://help.github.com/articles/ignoring-files/

# ─── dependencies ─────────────────────────────────────────────
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── environment (nunca secrets; templates *.example podem ser versionados) ─
.env
.env.*
.envrc
!.env.example
!.env.sample
!.env.server.example
.env.keys

# ─── Next.js (app na raiz) ────────────────────────────────────
.next/
out/
next-env.d.ts

# PWA — gerado em `npm run build` (@serwist/next → public/)
public/sw.js
public/sw.js.map
public/workbox-*.js
public/workbox-*.js.map
public/swe-worker-*.js
public/fallback-*.js

# ─── Vite / frontend SPA ──────────────────────────────────────
dist/
dev-dist/

# ─── build / bundlers ─────────────────────────────────────────
build/
.turbo/
.cache/
.parcel-cache/
.eslintcache

# ─── testing & coverage ───────────────────────────────────────
coverage/
*.lcov

# ─── Go (backend/) ───────────────────────────────────────────
backend/api
bin/
*.test
*.out

# ─── Supabase (CLI local) ─────────────────────────────────────
.branches/
supabase/.branches/
supabase/.temp/

# ─── Vercel ───────────────────────────────────────────────────
.vercel/

# ─── TypeScript (emit de `tsc -b` nos configs) ────────────────
*.tsbuildinfo
vite.config.js
vite.config.d.ts
vitest.config.js
vitest.config.d.ts

# ─── logs & debug ─────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── IDE / editor ─────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.cursor/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ─── certs & keys ─────────────────────────────────────────────
*.pem
*.p12

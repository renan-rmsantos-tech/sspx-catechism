# See https://help.github.com/articles/ignoring-files/

# ─── dependencies ─────────────────────────────────────────────
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── environment (nunca secrets; templates *.example podem ser versionados) ─
.env
.env.*
.envrc
!.env.example
!.env.sample
!.env.server.example
!backend/.env.example
.env.keys

# ─── Vite / frontend SPA ──────────────────────────────────────
dist/
dev-dist/

# ─── build / bundlers ─────────────────────────────────────────
build/
.turbo/
.cache/
.parcel-cache/
.eslintcache

# ─── testing & coverage ───────────────────────────────────────
coverage/
*.lcov

# ─── Go (backend/) ───────────────────────────────────────────
backend/api
bin/
*.test
*.out

# ─── TypeScript (emit de `tsc -b` nos configs) ────────────────
*.tsbuildinfo
vite.config.js
vite.config.d.ts
vitest.config.js
vitest.config.d.ts

# ─── logs & debug ─────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ─── IDE / editor ─────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.cursor/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ─── certs & keys ─────────────────────────────────────────────
*.pem
*.p12

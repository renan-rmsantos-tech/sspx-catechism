# Copie para `.env.local` e preencha (não commite `.env.local`).
# Dashboard: https://supabase.com/dashboard → seu projeto → Settings → API Keys
# Doc: https://supabase.com/docs/guides/api/api-keys

# Obrigatória — URL do projeto (cloud ou `http://127.0.0.1:54321` no `supabase start`).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Chave pública — use UMA das duas (o código prefere a publishable se as duas existirem):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<...>
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<jwt anon — legado>

# Chave só servidor (bypass RLS) — use UMA das duas:
SUPABASE_SECRET_KEY=sb_secret_<...>
# SUPABASE_SERVICE_ROLE_KEY=<jwt service_role — legado>

# Variáveis usadas pela Vercel (Production / Preview). Opcionalmente copie para
# `.env.local` apenas se for rodar build ou `next dev` na sua máquina.
#
# Dashboard: Supabase → Project Settings → API Keys
# Doc: https://supabase.com/docs/guides/api/api-keys

NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Chave pública — use UMA das duas (o código prefere publishable se ambas existirem):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<...>
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<jwt anon — legado>

# Chave só servidor (bypass RLS) — use UMA das duas — nunca em NEXT_PUBLIC_*:
SUPABASE_SECRET_KEY=sb_secret_<...>
# SUPABASE_SERVICE_ROLE_KEY=<jwt service_role — legado>

# Usuário admin (não pode ser apagado; criado no seed de desenvolvimento)
ADMIN_EMAIL=admin@catechism.dev
ADMIN_PASSWORD=admin123

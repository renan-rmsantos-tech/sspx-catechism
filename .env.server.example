# Copy to `.env` on the VPS (next to docker-compose.yml) and fill in real values.
# NEVER commit the real .env — it holds secrets.

# --- Domain (must point to the VPS public IP via a DNS A-record) ---
DOMAIN=catequese.example.org

# --- Postgres ---
POSTGRES_USER=catechism
POSTGRES_PASSWORD=change-me-strong-random
POSTGRES_DB=catechism

# Connection string the Go API uses (host "db" = the compose service name)
DATABASE_URL=postgres://catechism:change-me-strong-random@db:5432/catechism?sslmode=disable

# --- Auth ---
# 32+ random bytes, e.g. `openssl rand -base64 48`
JWT_SECRET=change-me-long-random-secret

# --- Admin bootstrap (created idempotently on API startup) ---
ADMIN_EMAIL=admin@example.org
ADMIN_PASSWORD=change-me-strong-admin-password

# --- Backup → Hetzner Storage Box (used by scripts/backup.sh) ---
# Storage Box SFTP credentials
STORAGEBOX_USER=u123456
STORAGEBOX_HOST=u123456.your-storagebox.de
STORAGEBOX_REMOTE_DIR=catechism-backups
# Optional: force the dedicated key used by backup/restore SFTP.
STORAGEBOX_SSH_KEY=/home/deploy/.ssh/storagebox
# Passphrase used to symmetrically encrypt dumps (age/gpg). Keep it safe & offline too.
BACKUP_PASSPHRASE=change-me-backup-encryption-passphrase
# Retention (days) for daily dumps
BACKUP_RETENTION_DAYS=14
